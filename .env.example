# Real Estate JC — variables de entorno (copia a .env y completa)
# En Expo solo las variables con prefijo EXPO_PUBLIC_ llegan a la app.

# Supabase → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Opcional: solo para scripts/server (NO incluir en builds de cliente)
# SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# Modo de datos: supabase
EXPO_PUBLIC_DATA_SOURCE=supabase
